# Copia a `.env` (misma carpeta). No subas `.env` a git.
# Carga automática: `app/database.py` → `load_dotenv`.
#
# Nivel de logs de la aplicación en consola (DEBUG, INFO, WARNING…). Por defecto INFO.
# LOG_LEVEL=INFO

# Local (Postgres en tu máquina o puerto mapeado desde Docker)
DATABASE_URL=postgresql://cerpal:cerpal@localhost:5432/cerpal

# Orígenes del frontend (CORS), separados por coma
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL pública del frontend (enlaces en correos de recuperación de contraseña). Sin barra final.
# PUBLIC_FRONTEND_URL=http://localhost:5173
# Caducidad del enlace (horas, entre 1 y 168). Por defecto 24.
# PASSWORD_RESET_TOKEN_HOURS=24

# Firma de JWT (obligatorio algo largo y aleatorio en producción)
# JWT_SECRET=
# JWT_EXPIRE_DAYS=7

# --- SMTP (fastapi-mail). Sin MAIL_SERVER no se envía nada. ---
#
# Gmail (ejemplo): puerto 587, STARTTLS, sin SSL implícito
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu_cuenta@gmail.com
# MAIL_PASSWORD=contraseña_de_aplicación
# MAIL_FROM=tu_cuenta@gmail.com
# MAIL_STARTTLS=true
# MAIL_SSL_TLS=false
#
# Mailjet: API Key = MAIL_USERNAME, Secret Key = MAIL_PASSWORD.
# Puerto 465 → MAIL_SSL_TLS=true (el código desactiva STARTTLS automáticamente).
# MAIL_FROM debe ser un remitente o dominio validado en el panel de Mailjet.
# Si la cuenta está en “modo sandbox”, solo llega a direcciones que hayas verificado.
# MAIL_FROM_NAME=Mi App (opcional, nombre visible junto al remitente)
# MAIL_EHLO_HOSTNAME: hostname en el saludo SMTP (EHLO). Vacío explícito = usar
# FQDN del sistema. Si no defines la variable, el backend usa mail.<dominio de MAIL_FROM>
# (útil en Docker; alinea mejor con dominios verificados en Mailjet).
# MAIL_SERVER=in-v3.mailjet.com
# MAIL_PORT=465
# MAIL_USERNAME=tu_api_key_mailjet
# MAIL_PASSWORD=tu_secret_key_mailjet
# MAIL_FROM=noreply@tudominio.com
# MAIL_SSL_TLS=true
