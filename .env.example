# Copia a `.env` (misma carpeta). No subas `.env` a git.
# Carga automática: `app/database.py` → `load_dotenv`.

# LOG_LEVEL=INFO

DATABASE_URL=postgresql://cerpal:cerpal@localhost:5432/cerpal

# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Enlaces en correos (sin barra final)
# PUBLIC_FRONTEND_URL=https://tu-dominio.com
# PASSWORD_RESET_TOKEN_HOURS=24

# JWT_SECRET=
# JWT_EXPIRE_DAYS=7

# --- SMTP (IONOS u otro). Sin MAIL_SERVER no se envía correo. ---
# MAIL_TIMEOUT=30
#
# IONOS (recomendado tras desbloquear SMTP en DigitalOcean):
# MAIL_SERVER=smtp.ionos.es
# MAIL_PORT=587
# MAIL_USERNAME=tu_correo@tudominio.com
# MAIL_PASSWORD=contraseña_del_buzon
# MAIL_FROM=tu_correo@tudominio.com
# MAIL_FROM_NAME=CERPAL
# MAIL_SSL_TLS=false
# MAIL_STARTTLS=true
#
# IONOS alternativa SSL:
# MAIL_PORT=465
# MAIL_SSL_TLS=true
#
# Pruebas locales sin enviar a internet (Mailpit: docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit):
# MAIL_SERVER=127.0.0.1
# MAIL_PORT=1025
# MAIL_USE_CREDENTIALS=false
# MAIL_STARTTLS=false
# MAIL_SSL_TLS=false
# MAIL_FROM=pruebas@cerpal.local
#
# MAIL_ORDER_NOTIFY=pedidos@tudominio.com
# BANK_TRANSFER_BENEFICIARY=CERPAL S.L.
# BANK_TRANSFER_BANK_NAME=Tu banco
# BANK_TRANSFER_IBAN=ES00 0000 0000 0000 0000 0000

# --- Redsys / TPV virtual (test o producción). No subas claves reales a git. ---
# REDSYS_ENV=test
# REDSYS_MERCHANT_CODE=tu_fuc
# REDSYS_TERMINAL=001
# REDSYS_SECRET_KEY=clave_secreta_del_comercio
# REDSYS_NOTIFICATION_URL=http://139.59.187.185:8000/api/pagos/redsys/notification
# REDSYS_URL_OK=http://138.68.141.65/mi-cuenta/pago/ok
# REDSYS_URL_KO=http://138.68.141.65/mi-cuenta/pago/ko
